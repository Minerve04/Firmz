# ─────────────────────────────────────────────
# FORGE — Environment variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# REQUIRED — Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — Vercel deployment (https://vercel.com/account/tokens)
# Without this, the landing page is generated but not deployed
VERCEL_TOKEN=...

# OPTIONAL — Stripe platform key (https://dashboard.stripe.com/apikeys)
# Use TEST key (sk_test_...) while building, LIVE key (sk_live_...) in prod
STRIPE_SECRET_KEY=sk_test_...

# OPTIONAL — Stripe Connect (https://dashboard.stripe.com/settings/connect)
# 1. Enable Connect in your Stripe dashboard (Connect > Get started)
# 2. Copy the client_id from Connect settings (starts with ca_...)
# 3. Add http://localhost:3000/api/stripe/callback as redirect URI
STRIPE_CLIENT_ID=ca_...
APP_URL=http://localhost:3000
# Firmz commission % on each transaction from connected founders (default 2%)
FIRMZ_COMMISSION_PERCENT=2

# OPTIONAL — Resend email (https://resend.com/api-keys)
# Requires a verified domain in your Resend account
RESEND_API_KEY=re_...
RESEND_FROM=Forge <noreply@yourdomain.com>

# Server port (default: 3000)
PORT=3000
